TELEGRAM_BOT_TOKEN=

LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
# One multimodal model for text chat and voice (production Gemini)
OPENROUTER_MODEL=google/gemini-2.5-flash
# Cheaper text-only (no voice): meta-llama/llama-3.3-70b-instruct
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MAX_OUTPUT_TOKENS=1024
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_BASE_DELAY_SECONDS=1.0
OPENROUTER_RETRY_MAX_DELAY_SECONDS=8.0
OPENROUTER_TIMEOUT_SECONDS=120.0

# Only if LLM_PROVIDER=gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY_SECONDS=1.0
GEMINI_RETRY_MAX_DELAY_SECONDS=8.0

DATABASE_URL=postgresql://lashbot:lashbot@postgres:5432/lashbot
RECAP_MESSAGE_COUNT=50
MAX_TRANSCRIPT_CHARS=80000
CHAT_COOLDOWN_SECONDS=3

ALLOWED_CHAT_IDS=
LOG_LEVEL=INFO
