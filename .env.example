TELEGRAM_BOT_TOKEN=
GOOGLE_API_KEY=
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_OUTPUT_TOKENS=1024
# Retries after the first attempt (3 = up to 4 total calls on 503/429)
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY_SECONDS=1.0
GEMINI_RETRY_MAX_DELAY_SECONDS=8.0

DATABASE_URL=postgresql://lashbot:lashbot@postgres:5432/lashbot
RECAP_MESSAGE_COUNT=50
MAX_TRANSCRIPT_CHARS=80000
CHAT_COOLDOWN_SECONDS=3

# optional: comma-separated chat IDs; empty = all groups
ALLOWED_CHAT_IDS=

LOG_LEVEL=INFO
